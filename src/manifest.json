{
  "manifest_version": 3,
  "name": "WebGist",
  "version": "1.0.1",
  "description": "Summarize any webpage with AI. Translate to 84 languages, read aloud, export PDF. 7 free AI providers — no sign-up needed.",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "toggle-panel": {
      "suggested_key": { "default": "Alt+G" },
      "description": "Open/close WebGist panel"
    },
    "summarize": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Summarize current page"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["popup/index.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "storage", "offscreen", "tabs", "contextMenus"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "https://api.deepseek.com/*",
    "https://api.cerebras.ai/*",
    "https://api.sambanova.ai/*",
    "https://api.together.xyz/*",
    "https://integrate.api.nvidia.com/*",
    "https://api.moonshot.ai/*",
    "https://api.mistral.ai/*",
    "https://api.cohere.ai/*",
    "https://openrouter.ai/*",
    "https://api.anthropic.com/*",
    "https://translate.googleapis.com/*",
    "https://translate.google.com/*",
    "https://r.jina.ai/*",
    "http://127.0.0.1:7777/*",
    "http://localhost:11434/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

{
  "manifest_version": 3,
  "name": "WebGist",
  "version": "1.0.0",
  "description": "Summarize any webpage with AI. Translate to 84 languages, read aloud, export PDF. 7 free AI providers — no sign-up needed.",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/index.html"
  },
  "background": {
    "service_worker": "background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "scripting", "storage", "offscreen", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:7777/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
